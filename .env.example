# PostgreSQL bağlantısı (docker-compose ve prod profili tarafından kullanılır).
# Gerçek değerlerle .env olarak kopyalayın: cp .env.example .env

DB_NAME=abilet
DB_USER=abilet
DB_PASSWORD=change-me

# Uygulamanın bağlanacağı host/port. docker-compose host portunu DB_PORT olarak
# yayınlar (DB_PORT:5432); prod profili de aynı DB_HOST/DB_PORT'u kullanır.
DB_HOST=localhost
DB_PORT=5432
